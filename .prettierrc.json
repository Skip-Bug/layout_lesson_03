{
  "printWidth": 10000,
  "proseWrap": "never",
  "htmlWhitespaceSensitivity": "ignore",
  "singleAttributePerLine": false,
  "embeddedLanguageFormatting": "auto",
  "overrides": [
    { "files": "*.html", "options": { "parser": "html" } },
    { "files": "template.html", "options": { "parser": "html", "embeddedLanguageFormatting": "auto" } }
  ]
}
